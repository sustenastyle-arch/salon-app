# Square Developer Dashboard (developer.squareup.com) の
# Access Token と Location ID をここに入れて、ファイル名を .env にリネームしてください。
# .env は .gitignore 済みなのでGitHubには上がりません。

SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=J84JMVZ7QNE10

# PIN to unlock a "確定済み" (locked/submitted) day's sales sheet.
VITE_MANAGER_PIN=1234

# Shared password to open the whole site — only needed once the app is hosted somewhere
# reachable over the internet (not just localhost). Leave unset for local-only use.
VITE_APP_PASSWORD=
