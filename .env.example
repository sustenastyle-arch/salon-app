# Square Developer Dashboard (developer.squareup.com) の
# Access Token と Location ID をここに入れて、ファイル名を .env にリネームしてください。
# .env は .gitignore 済みなのでGitHubには上がりません。

SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=J84JMVZ7QNE10

# PIN to unlock a "確定済み" (locked/submitted) day's sales sheet.
VITE_MANAGER_PIN=1234

# Shared password to open the whole site — only needed once the app is hosted somewhere
# reachable over the internet (not just localhost). Leave unset for local-only use.
# Also doubles as the shared-secret header for the cloud data API (see api/_lib/dayDataStore.js).
VITE_APP_PASSWORD=

# Upstash Redis — shared cloud store so every computer sees the same daily-sheet data
# instead of each browser keeping its own copy in localStorage. Provisioned via Vercel's
# dashboard (Storage tab → Upstash for Redis); copy the two REST values shown there into
# your local .env by hand (Project Settings → Environment Variables).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional — verifies that requests to /api/auto-backup (the once-daily automatic snapshot,
# see vercel.json's cron schedule) actually came from Vercel's own Cron scheduler. Set this to
# any random string in the Vercel dashboard's env vars; Vercel automatically sends it back as
# an Authorization header on the cron's own requests. Leave unset to skip the check (fine for
# local dev, since crons don't run under `vite dev` anyway).
CRON_SECRET=
